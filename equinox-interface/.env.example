# ================================================
# EQUINOX - Multi-Collateral DeFi Lending Protocol
# ================================================

# Environment Mode
# Options: mock | real
# - mock: Uses mock data for demo/development
# - real: Connects to Sui blockchain with real contract data
NEXT_PUBLIC_APP_MODE=real

# Sui Network Configuration
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Contract Addresses (Testnet - Deployed 2026-02-08)
# Main package containing all modules
NEXT_PUBLIC_PACKAGE_ID=0x60db99c5af7bea80b5ff36922cf73964688923449e59347457be8e6e20e4c13a
NEXT_PUBLIC_REGISTRY_ID=0xa62c9a091b001bb7e76fb416c8a87e426e468bca4d05a01f8c0418d4b762b741
NEXT_PUBLIC_VESTING_VAULT_ID=0x50b306dc4d0301582fb13d11d7e09ad8de1bae7f23b89e72ab3664b63561c65f
# Market object ID for orderbook (create via market::create_market_standalone)
NEXT_PUBLIC_MARKET_ID=
NEXT_PUBLIC_USDC_ADMIN_CAP_ID=0xffa94cd074e29ce7fbe7aa43690144b53afeec6aaa5c6239eb3090434c78c62d
NEXT_PUBLIC_ETH_ADMIN_CAP_ID=0x9e18bfaa3227bc3ff2117d38a061fbdba372f02c66581ce7279b264a73573e5c
NEXT_PUBLIC_ORDERBOOK_PACKAGE_ID=0x60db99c5af7bea80b5ff36922cf73964688923449e59347457be8e6e20e4c13a
NEXT_PUBLIC_LOAN_OBJECT_PACKAGE_ID=0x60db99c5af7bea80b5ff36922cf73964688923449e59347457be8e6e20e4c13a
NEXT_PUBLIC_VESTING_VAULT_PACKAGE_ID=0x60db99c5af7bea80b5ff36922cf73964688923449e59347457be8e6e20e4c13a

# zkLogin Configuration (Optional - for Google OAuth login)
# Get your Google Client ID from https://console.cloud.google.com
# 1. Create OAuth 2.0 credentials (Web application type)
# 2. Add authorized JavaScript origins: http://localhost:3000
# 3. Add authorized redirect URIs: http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000/auth/callback

# Enoki Configuration (REQUIRED for zkLogin with custom OAuth credentials)
# Mysten Labs prover service only accepts whitelisted OAuth client IDs.
# To use your own Google Client ID, you MUST use Enoki:
# 1. Go to https://portal.enoki.mystenlabs.com
# 2. Create a new application
# 3. Add Google as authentication provider with your Client ID above
# 4. Copy the API Key and paste it below
NEXT_PUBLIC_ENOKI_API_KEY=

# Oracle Configuration
# Options: pyth | supra
# - pyth: Uses Pyth Network for real-time price feeds
# - supra: Uses Supra Oracle (not yet implemented)
NEXT_PUBLIC_PRICE_ORACLE=pyth

# Feature Flags
NEXT_PUBLIC_ENABLE_ZK_ORDERS=true
NEXT_PUBLIC_ENABLE_AI_MATCHING=true
NEXT_PUBLIC_ENABLE_VESTING_VAULT=true

# Auto-match: minimum Nautilus fairness score (0-100) required to settle. 0 disables the gate.
NEXT_PUBLIC_MIN_FAIRNESS_SCORE=0

# Optional: Nautilus enclave registered on-chain. When unset, auto-match falls back to the
# deterministic match_best_offer entry that does not require a fairness proof.
# NEXT_PUBLIC_NAUTILUS_ENCLAVE_ID=
# NEXT_PUBLIC_NAUTILUS_DEV_PRIVATE_KEY=

# Aggregator vault (Nautilus-driven yield router) — see contracts/equinox/sources/vault.move
# NEXT_PUBLIC_AGGREGATOR_VAULT_ID=
# NEXT_PUBLIC_AGGREGATOR_VAULT_ASSET=USDC
# Comma-separated Market<Asset, Collateral> object IDs the auto-allocator may route into.
# NEXT_PUBLIC_VAULT_MARKETS=

# =====================================================================
# DeepBook Predict — PLP+Hedge Vault (Sui Overflow track). Defaults in
# lib/predict/config.ts already point at the live testnet deployment, so
# these are only needed to override or to run the keeper/strategist.
# =====================================================================
# NEXT_PUBLIC_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
# NEXT_PUBLIC_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
# NEXT_PUBLIC_PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
# NEXT_PUBLIC_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
# NEXT_PUBLIC_VAULT_PACKAGE_ID=0xd4d556eea3435ff1f2a102b784ba1cc00a116c277513f73242409ad762a55e39
# NEXT_PUBLIC_VAULT_ID=0x14e0ef423ca0d50e0b47b0b225ad3fd510cc2ca2ce6cafc7d4bcabf25596c391
# NEXT_PUBLIC_VAULT_MANAGER_ID=0x0de4ed88b9c7e7c2fe60b9cb064c45580884389f1cc800f31584366856aa1711
# NEXT_PUBLIC_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# Keeper / strategist service (server-side only — NEVER commit real values)
# DEPLOYER_MNEMONIC=        # keeper wallet that owns the PredictManager
# STRATEGIST_SK=suiprivkey...# ed25519 strategist key that signs allocation legs
